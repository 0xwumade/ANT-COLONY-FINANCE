# Ant Colony Finance — Environment Config
# Copy this to .env and fill in your values

# ── Base Network ──────────────────────────────
BASE_RPC_URL=https://mainnet.base.org
BASE_CHAIN_ID=8453
BASE_TESTNET_RPC_URL=https://sepolia.base.org
BASE_TESTNET_CHAIN_ID=84532

# ── CDP Wallet (Coinbase Developer Platform) ──
CDP_API_KEY_NAME=your_cdp_api_key_name
CDP_API_KEY_PRIVATE_KEY=your_cdp_private_key
CDP_WALLET_ID=your_wallet_id

# ── Treasury ──────────────────────────────────
TREASURY_PRIVATE_KEY=your_treasury_wallet_private_key
TREASURY_ADDRESS=0xYourTreasuryAddress

# ── DEX Contracts (Base Mainnet) ──────────────
UNISWAP_V3_ROUTER=0x2626664c2603336E57B271c5C0b26F421741e481
AERODROME_ROUTER=0xcF77a3Ba9A5CA399B7c97c74d54e5b1Beb874E43

# ── Redis ─────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_DB=0

# ── Data Sources ──────────────────────────────
COINGECKO_API_KEY=your_coingecko_api_key
TWITTER_BEARER_TOKEN=your_twitter_bearer_token
DUNE_API_KEY=your_dune_api_key

# ── Swarm Config ──────────────────────────────
SWARM_SIZE=100                  # Number of agents per caste
CONSENSUS_THRESHOLD=0.65        # 65% weighted score to trigger trade
SIGNAL_WINDOW_SECONDS=60        # Voting window per cycle
MAX_TRADE_SIZE_ETH=0.1          # Max ETH per trade
MIN_TRADE_SIZE_ETH=0.01         # Min ETH per trade

# ── Smart Contract ────────────────────────────
COLONY_CONTRACT_ADDRESS=0xDeployedContractAddress
